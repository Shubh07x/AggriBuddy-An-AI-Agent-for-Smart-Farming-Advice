# ── AggriBuddy Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit your actual .env file to GitHub!

# IBM Cloud API Key (get from cloud.ibm.com → Manage → Access → API Keys)
IBM_API_KEY=your_ibm_cloud_api_key_here

# Watsonx Project ID (get from Watsonx.ai Studio → Project Settings)
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# IBM Watsonx URL (default for us-south region)
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Local paths
DOCS_DIR=./docs
VECTOR_DIR=./vectorstore
